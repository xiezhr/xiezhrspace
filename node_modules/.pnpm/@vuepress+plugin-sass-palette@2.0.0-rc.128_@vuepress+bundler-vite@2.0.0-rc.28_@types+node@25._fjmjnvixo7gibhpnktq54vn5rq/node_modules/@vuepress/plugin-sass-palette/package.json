{
  "name": "@vuepress/plugin-sass-palette",
  "version": "2.0.0-rc.128",
  "description": "VuePress plugin - sass-palette",
  "keywords": [
    "palette",
    "sass",
    "vuepress",
    "vuepress-plugin"
  ],
  "homepage": "https://ecosystem.vuejs.press/plugins/development/sass-palette/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "plugins/development/plugin-sass-palette"
  },
  "files": [
    "dist",
    "styles"
  ],
  "type": "module",
  "sideEffects": [
    "./styles/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./helper": {
      "sass": "./styles/helper.scss"
    },
    "./empty": {
      "sass": "./styles/empty.scss"
    },
    "./empty.scss": "./styles/empty.scss",
    "./helper.scss": "./styles/helper.scss",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vuepress/helper": "2.0.0-rc.128",
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.28",
    "@vuepress/bundler-webpack": "2.0.0-rc.28"
  },
  "peerDependencies": {
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "sass-loader": "^16.0.7",
    "vuepress": "2.0.0-rc.28"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": true
    },
    "sass-embedded": {
      "optional": true
    },
    "sass-loader": {
      "optional": true
    }
  },
  "gitHead": "47b25c2008dc496e4638cae7528374846d3660dd"
}
